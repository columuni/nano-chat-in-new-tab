{
  "manifest_version": 3,
  "name": "Nano Chat in New Tab",
  "version": "1.0",
  "description": "Chromeの新しいタブページにGoogleがChromeに組み込んだオンデバイスAIであるGemini Nanoを搭載したAIチャットインターフェイスを表示するChrome拡張機能です。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "nanochat.html"
  },
  "host_permissions": [
    "https://www.google.com/*"
  ]
}
